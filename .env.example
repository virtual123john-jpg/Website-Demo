# --- OpenAI (required) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- n8n integration ---
# This project expects you to run n8n yourself (e.g. your own self-hosted
# n8n Community Edition container publishing port 5678 on the host, such as
# a container named "n8n-local"). docker-compose.yml already points the web
# container at it via http://host.docker.internal:5678/webhook/medigap-chat
# — you do not need to set N8N_WEBHOOK_URL here for the Docker Compose flow.
#
# If you run `npm run dev` directly on the host (no Docker for the website),
# use the plain localhost form instead:
#   N8N_WEBHOOK_URL=http://localhost:5678/webhook/medigap-chat
#
# Leave N8N_WEBHOOK_URL unset entirely for Vercel production — the app falls
# back to calling OpenAI directly, which is the supported production path.
